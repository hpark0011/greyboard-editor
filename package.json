{
  "name": "greyboard",
  "version": "0.0.1",
  "private": true,
  "main": "dist/main/index.js",
  "workspaces": ["packages/*", "packages/features/*"],
  "scripts": {
    "dev": "bun run build:preload && concurrently -k -n main,renderer,electron -c blue,green,yellow \"bun run dev:main\" \"bun run dev:renderer\" \"bun run dev:electron\"",
    "dev:main": "bun build src/main/index.ts --outdir dist/main --target node --format cjs --external electron --watch",
    "dev:renderer": "cd src/renderer && vite",
    "dev:electron": "wait-on http://localhost:5173 && electronmon dist/main/index.js",
    "build:main": "bun build src/main/index.ts --outdir dist/main --target node --format cjs --external electron",
    "build:preload": "bun build src/preload/index.ts --outdir dist/preload --target node --format cjs --external electron",
    "build:renderer": "cd src/renderer && vite build",
    "build": "bun run build:main && bun run build:preload && bun run build:renderer",
    "start": "electron dist/main/index.js",
    "typecheck": "tsc --noEmit",
    "test:smoke": "bun scripts/smoke-test.ts",
    "dev:clean": "lsof -ti :5173 | xargs kill -9 2>/dev/null; pkill -f electronmon 2>/dev/null; echo 'Cleaned'",
    "dev:safe": "bun run dev:clean && bun run dev"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.1.2",
    "electron": "^33.3.1",
    "electronmon": "^2.0.4",
    "typescript": "^5.7.3",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@feel-good/icons": "workspace:*",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@vitejs/plugin-react": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tiptap-markdown": "^0.9.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.0",
    "zustand": "^5.0.11"
  }
}
